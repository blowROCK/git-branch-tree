{
  "name": "git-branch-tree",
  "displayName": "Git Branch Tree",
  "description": "%description%",
  "version": "0.5.1",
  "publisher": "zzumbong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blowROCK/git-branch-tree.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "branch",
    "tree",
    "checkout",
    "switch",
    "branches"
  ],
  "galleryBanner": {
    "color": "#312E81",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "l10n": "./l10n",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitBranchTree",
          "title": "Branch Tree",
          "icon": "media/branch-tree.svg"
        }
      ]
    },
    "views": {
      "gitBranchTree": [
        {
          "id": "gitBranchTree.view",
          "name": "%view.branches%",
          "icon": "media/branch-tree.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitBranchTree.view",
        "contents": "%welcome%"
      }
    ],
    "commands": [
      {
        "command": "gitBranchTree.refresh",
        "title": "%cmd.refresh%",
        "category": "Branch Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "gitBranchTree.checkout",
        "title": "%cmd.checkout%",
        "category": "Branch Tree"
      },
      {
        "command": "gitBranchTree.deleteLocalBranch",
        "title": "%cmd.deleteLocal%",
        "category": "Branch Tree",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchTree.deleteRemoteBranch",
        "title": "%cmd.deleteRemote%",
        "category": "Branch Tree",
        "icon": "$(trash)"
      },
      {
        "command": "gitBranchTree.fetchPrune",
        "title": "%cmd.fetchPrune%",
        "category": "Branch Tree",
        "icon": "$(sync)"
      },
      {
        "command": "gitBranchTree.createBranch",
        "title": "%cmd.createBranch%",
        "category": "Branch Tree",
        "icon": "$(add)"
      },
      {
        "command": "gitBranchTree.expandAll",
        "title": "%cmd.expandAll%",
        "category": "Branch Tree",
        "icon": "$(expand-all)"
      },
      {
        "command": "gitBranchTree.loadMoreCommits",
        "title": "%cmd.loadMore%",
        "category": "Branch Tree"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitBranchTree.createBranch",
          "when": "view == gitBranchTree.view",
          "group": "navigation@1"
        },
        {
          "command": "gitBranchTree.fetchPrune",
          "when": "view == gitBranchTree.view",
          "group": "navigation@2"
        },
        {
          "command": "gitBranchTree.refresh",
          "when": "view == gitBranchTree.view",
          "group": "navigation@3"
        },
        {
          "command": "gitBranchTree.expandAll",
          "when": "view == gitBranchTree.view",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "gitBranchTree.checkout",
          "when": "view == gitBranchTree.view && viewItem =~ /^(localBranch|remoteBranch)$/",
          "group": "1_checkout@1"
        },
        {
          "command": "gitBranchTree.createBranch",
          "when": "view == gitBranchTree.view && viewItem =~ /^(localBranch|remoteBranch|currentBranch)$/",
          "group": "2_create@1"
        },
        {
          "command": "gitBranchTree.fetchPrune",
          "when": "view == gitBranchTree.view && viewItem == remoteSection",
          "group": "1_fetch@1"
        },
        {
          "command": "gitBranchTree.deleteLocalBranch",
          "when": "view == gitBranchTree.view && viewItem == localBranch",
          "group": "7_modification@1"
        },
        {
          "command": "gitBranchTree.deleteRemoteBranch",
          "when": "view == gitBranchTree.view && viewItem == remoteBranch",
          "group": "7_modification@1"
        }
      ],
      "commandPalette": [
        {
          "command": "gitBranchTree.checkout",
          "when": "false"
        },
        {
          "command": "gitBranchTree.deleteLocalBranch",
          "when": "false"
        },
        {
          "command": "gitBranchTree.deleteRemoteBranch",
          "when": "false"
        },
        {
          "command": "gitBranchTree.loadMoreCommits",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "vsix": "mkdir -p release && vsce package --out release"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
